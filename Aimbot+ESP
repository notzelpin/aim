local Players = game:GetService("Players")
local player = Players.LocalPlayer
local camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")

local espCache = {}
local boxCache = {}

local globalParams = RaycastParams.new()
globalParams.FilterType = Enum.RaycastFilterType.Blacklist
local globalIgnore = {}

local function checkPartVisible(part)
	local origin = camera.CFrame.Position
	local cf = part.CFrame
	local size = part.Size / 2
	local corners = {
		part.Position,
		cf * Vector3.new(size.X, size.Y, 0),
		cf * Vector3.new(-size.X, size.Y, 0),
		cf * Vector3.new(0, -size.Y, size.Z),
		cf * Vector3.new(0, -size.Y, -size.Z)
	}

	for _, targetPos in ipairs(corners) do
		local direction = (targetPos - origin)
		local pointVisible = false

		while true do
			globalParams.FilterDescendantsInstances = globalIgnore
			local ray = workspace:Raycast(origin, direction, globalParams)
			if ray then
				if ray.Instance:IsA("BasePart") and ray.Instance.Transparency >= 1 then
					table.insert(globalIgnore, ray.Instance)
					continue
				end
				pointVisible = false
				break
			else
				pointVisible = true
				break
			end
		end

		if pointVisible then return true end
	end
	return false
end

local function setup(plr)
	if plr == player then return end

	local g = Instance.new("BillboardGui")
	g.Size = UDim2.new(0, 200, 0, 50)
	g.AlwaysOnTop = true
	local l = Instance.new("TextLabel", g)
	l.Size = UDim2.new(1, 0, 1, 0)
	l.BackgroundTransparency = 1
	l.TextScaled = true

	local box = Drawing.new("Square")
	box.Thickness = 1
	box.Filled = false

	espCache[plr] = {g = g, l = l, hList = {}}
	boxCache[plr] = box
end

for _, p in pairs(Players:GetPlayers()) do setup(p) end
Players.PlayerAdded:Connect(setup)

-- ESP LOOP
RunService.RenderStepped:Connect(function()
	globalIgnore = {}
	for _, p in pairs(Players:GetPlayers()) do
		if p.Character then table.insert(globalIgnore, p.Character) end
	end

	for plr, data in pairs(espCache) do
		local char = plr.Character
		local root = char and char:FindFirstChild("HumanoidRootPart")
		local humanoid = char and char:FindFirstChildOfClass("Humanoid")
		local box = boxCache[plr]

		if data.h and data.h.Parent then
			data.h:Destroy()
			data.h = nil
		end

		if not espStates.Enabled or not char or not humanoid or humanoid.Health <= 0 then
			if data.hList then for _, h in pairs(data.hList) do h.Enabled = false end end
			if data.g.Parent ~= nil then data.g.Parent = nil end
			box.Visible = false
			continue
		end

		if espStates.TeamCheck then
			local isSameTeam = false
			if espStates.TeamCheckOption == "TeamColor" then
				isSameTeam = (plr.TeamColor == player.TeamColor)
			else
				isSameTeam = (plr.Team == player.Team)
			end
			
			if isSameTeam then
				if data.hList then for _, h in pairs(data.hList) do h.Enabled = false end end
				if data.g.Parent ~= nil then data.g.Parent = nil end
				box.Visible = false
				continue
			end
		end

		local defaultColor = Color3.new(1, 0, 0)
		if espStates.TeamCheck or espStates.TeamColors then
			defaultColor = plr.TeamColor.Color
		end

		local anyVisible = false
		if not data.hList then data.hList = {} end

		if espStates.WallCheckTurnoff then
			if data.h and data.h.Parent then
				data.h:Destroy()
				data.h = nil
			end
			
			for _, part in ipairs(char:GetDescendants()) do
				if part:IsA("BasePart") and part.Transparency < 1 then
					local isVis = checkPartVisible(part)
					if isVis then anyVisible = true end
					
					local hl = data.hList[part]
					if not hl then
						hl = Instance.new("Highlight")
						hl.OutlineTransparency = 1
						hl.FillTransparency = 0.5
						hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
						hl.Adornee = part
						hl.Parent = part
						data.hList[part] = hl
					end
					
					hl.Enabled = true
					hl.FillColor = isVis and defaultColor or Color3.new(1, 1, 1)
				end
			end
		else
			for part, hl in pairs(data.hList) do
				hl:Destroy()
				data.hList[part] = nil
			end
            
			if not data.h or not data.h.Parent then
				local hl = Instance.new("Highlight")
				hl.OutlineTransparency = 1
				hl.FillTransparency = 0.5
				hl.Adornee = char
				hl.Parent = char
				data.h = hl
			end
            
			data.h.Enabled = true
			data.h.FillColor = defaultColor
            
			if espStates.WallCheck then
				data.h.DepthMode = Enum.HighlightDepthMode.Occluded
				anyVisible = true
			else
				data.h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
				anyVisible = true
			end
		end

		for part, hl in pairs(data.hList) do
			if not part or not part.Parent or not part:IsDescendantOf(char) then
				hl:Destroy()
				data.hList[part] = nil
			end
		end

		if espStates.WallCheckTurnoff and not anyVisible then
			if data.g.Parent ~= nil then data.g.Parent = nil end
			box.Visible = false
			continue
		end

		if data.g.Parent ~= root then data.g.Parent = root end
		local text = ""
		if espStates.Name then text = text .. plr.Name .. "\n" end
		data.l.Text = text

		if espStates.Boxes and root then
			local pos, vis = camera:WorldToViewportPoint(root.Position)
			if vis then
				local topY = camera:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0)).Y
				local size = math.abs((topY - pos.Y) * 2)
				local width = size / 2
				box.Size = Vector2.new(width, size)
				box.Position = Vector2.new(pos.X - width/2, pos.Y - size/2)
				box.Color = defaultColor
				box.Visible = true
			else
				box.Visible = false
			end
		else
			box.Visible = false
		end
	end
end)
