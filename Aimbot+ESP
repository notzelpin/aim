--// AIMBOT LOGIC STARTS HERE //--
local function visibleCheck(part)
	if not aimbotStates.WallCheck then return true end

	local origin = camera.CFrame.Position
	local direction = (part.Position - origin)

	local params = RaycastParams.new()
	local ignoreList = {player.Character}
	params.FilterType = Enum.RaycastFilterType.Blacklist

	while true do
		params.FilterDescendantsInstances = ignoreList
		local ray = workspace:Raycast(origin, direction, params)
		if ray then
			if ray.Instance:IsA("BasePart") and (ray.Instance.Transparency >= 1 or not ray.Instance.CanCollide) then
				table.insert(ignoreList, ray.Instance)
				continue
			end
			return ray.Instance:IsDescendantOf(part.Parent)
		end
		return true
	end
end

-- DRAW
local circle = Drawing.new("Circle")
circle.Color = Color3.fromRGB(0,170,255)
circle.Filled = false

-- AIM LOOP
RunService:BindToRenderStep("Aimbot", Enum.RenderPriority.Camera.Value + 1, function()
	local aimCenter
	if aimbotStates.LockMode == "mousemoverel" then
		aimCenter = UIS:GetMouseLocation()
	else
		aimCenter = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
	end

	circle.Position = aimCenter
	circle.Radius = aimbotStates.FOV
	circle.Visible = aimbotStates.Enabled and aimbotStates.ShowFov

	if aimbotStates.Enabled and aimbotStates.Aiming then
		local bestNeutral, distNeutral = nil, aimbotStates.FOV
		local bestPriority, distPriority = nil, aimbotStates.FOV

		for _, v in pairs(Players:GetPlayers()) do
			if v ~= player and v.Character then
				local part
				
				if aimbotStates.Target == "HumanoidRootPart" then
					part = v.Character:FindFirstChild("HumanoidRootPart")
				else
					part = v.Character:FindFirstChild("Head") or v.Character:FindFirstChild("HumanoidRootPart")
				end

				if not part then
					part = v.Character:FindFirstChildWhichIsA("BasePart")
				end

				if not part then continue end

				if aimbotStates.TeamCheck then
					local isSameTeam = false
					if aimbotStates.TeamCheckOption == "TeamColor" then
						isSameTeam = (v.TeamColor == player.TeamColor)
					else
						isSameTeam = (v.Team == player.Team)
					end
					if isSameTeam then continue end
				end

				local status = playerStatuses[v.Name] or "neutral"
				if status == "friendly" then continue end

				local pos, onScreen = camera:WorldToViewportPoint(part.Position)

				if onScreen then
					local mag = (Vector2.new(pos.X, pos.Y) - aimCenter).Magnitude
					if visibleCheck(part) then
						if status == "priority" then
							if mag < distPriority then
								distPriority = mag
								bestPriority = part
							end
						else
							if mag < distNeutral then
								distNeutral = mag
								bestNeutral = part
							end
						end
					end
				end
			end
		end

		local best = bestPriority or bestNeutral

		if best then
			if aimbotStates.LockMode == "CFrame" then
				local newCF = CFrame.new(camera.CFrame.Position, best.Position)
				camera.CFrame = camera.CFrame:Lerp(newCF, aimbotStates.Smoothing)

				-- FORCE TOOL AIM
				pcall(function()
					local char = player.Character
					if not char then return end

					local tool = char:FindFirstChildOfClass("Tool")
					if tool then
						for _, v in pairs(tool:GetDescendants()) do
							if v:IsA("BasePart") then
								v.CFrame = CFrame.new(v.Position, best.Position)
							end
						end
					end
				end)
				
				-- FORCE TOOL ALIGNMENT
				pcall(function()
					local tool = player.Character and player.Character:FindFirstChildOfClass("Tool")
					if tool and tool:FindFirstChild("Handle") then
						tool.Handle.CFrame = CFrame.new(tool.Handle.Position, best.Position)
					end
				end)
			elseif aimbotStates.LockMode == "mousemoverel" then
				local pos = camera:WorldToViewportPoint(best.Position)
				local mousePos = UIS:GetMouseLocation()
				local diffX = pos.X - mousePos.X
				local diffY = pos.Y - mousePos.Y
				
				if mousemoverel then
					mousemoverel(diffX * aimbotStates.Smoothing, diffY * aimbotStates.Smoothing)
				end
			end
		end
	end
end)
