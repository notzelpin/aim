local Players = game:GetService("Players")
local player = Players.LocalPlayer
local camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")

local espCache = {}
local boxCache = {}

local function setup(plr)
	if plr == player then return end

	local h = Instance.new("Highlight")
	h.OutlineTransparency = 1
	h.FillTransparency = 0.5
	local g = Instance.new("BillboardGui")
	g.Size = UDim2.new(0, 200, 0, 50)
	g.AlwaysOnTop = true
	local l = Instance.new("TextLabel", g)
	l.Size = UDim2.new(1, 0, 1, 0)
	l.BackgroundTransparency = 1
	l.TextScaled = true

	local box = Drawing.new("Square")
	box.Thickness = 1
	box.Filled = false

	espCache[plr] = {h = h, g = g, l = l}
	boxCache[plr] = box
end

for _, p in pairs(Players:GetPlayers()) do setup(p) end
Players.PlayerAdded:Connect(setup)

-- ESP LOOP
RunService.RenderStepped:Connect(function()
	for plr, data in pairs(espCache) do
		local char = plr.Character
		local root = char and char:FindFirstChild("HumanoidRootPart")
		local box = boxCache[plr]

		if not espStates.Enabled or not char then
			if data.h.Parent ~= nil then data.h.Parent = nil end
			if data.g.Parent ~= nil then data.g.Parent = nil end
			box.Visible = false
			continue
		end

		if espStates.TeamCheck then
			local isSameTeam = false
			if espStates.TeamCheckOption == "TeamColor" then
				isSameTeam = (plr.TeamColor == player.TeamColor)
			else
				isSameTeam = (plr.Team == player.Team)
			end
			
			if isSameTeam then
				if data.h.Parent ~= nil then data.h.Parent = nil end
				if data.g.Parent ~= nil then data.g.Parent = nil end
				box.Visible = false
				continue
			end
		end

		local isBehindWall = false
		if (espStates.WallCheck or espStates.WallCheckTurnoff) and root then
			local origin = camera.CFrame.Position
			local direction = (root.Position - origin)
			local params = RaycastParams.new()
			local ignoreList = {player.Character}
			params.FilterType = Enum.RaycastFilterType.Blacklist
			
			while true do
				params.FilterDescendantsInstances = ignoreList
				local ray = workspace:Raycast(origin, direction, params)
				if ray then
					if ray.Instance:IsA("BasePart") and (ray.Instance.Transparency >= 1 or not ray.Instance.CanCollide) then
						table.insert(ignoreList, ray.Instance)
						continue
					end
					if not ray.Instance:IsDescendantOf(char) then
						isBehindWall = true
					end
				end
				break
			end
		end

		if espStates.WallCheckTurnoff and isBehindWall then
			if data.h.Parent ~= nil then data.h.Parent = nil end
			if data.g.Parent ~= nil then data.g.Parent = nil end
			box.Visible = false
			continue
		end

		local defaultColor = Color3.new(1, 0, 0)
		if espStates.TeamCheck or espStates.TeamColors then
			defaultColor = plr.TeamColor.Color
		end

		local color = defaultColor
		if espStates.WallCheck and isBehindWall then
			color = Color3.new(1, 1, 1)
		end

		if data.h.Parent ~= char then data.h.Parent = char end
		data.h.FillColor = color

		if data.g.Parent ~= root then data.g.Parent = root end
		local text = ""
		if espStates.Name then text = text .. plr.Name .. "\n" end
		data.l.Text = text

		if espStates.Boxes and root then
			local pos, vis = camera:WorldToViewportPoint(root.Position)
			if vis then
				local topY = camera:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0)).Y
				local size = math.abs((topY - pos.Y) * 2)
				local width = size / 2
				box.Size = Vector2.new(width, size)
				box.Position = Vector2.new(pos.X - width/2, pos.Y - size/2)
				box.Color = color
				box.Visible = true
			else
				box.Visible = false
			end
		else
			box.Visible = false
		end
	end
end)
